{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": "${configDir}",
    "rootDir": "${configDir}/src",
    "outDir": "${configDir}/dist",
    "noEmit": false
  },
  "exclude": [
    "${configDir}/node_modules",
    "${configDir}/dist",
    "${configDir}/test",
    "${configDir}/*.config.ts",
    "${configDir}/src/**/*.test.ts"
  ]
}
