{
  "name": "automo",
  "private": true,
  "version": "0.0.0",
  "description": "The Automo application",
  "keywords": [
    "agenda-app",
    "typescript"
  ],
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint --cache --cache-location=../../node_modules/.cache/.eslintcache",
    "lint:fix": "pnpm -r lint:fix",
    "start:dev:full": "concurrently -n server,web -c green,blue \"pnpm -F @agenda-app/server start:dev:full\" \"pnpm -F @agenda-app/web dev\"",
    "generate:client": "pnpm -F @agenda-app/client codegen"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}