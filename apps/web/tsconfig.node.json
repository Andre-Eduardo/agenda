{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strictNullChecks": true,
    "outDir": "dist"
  },
  "include": ["vite.config.ts", "src/views/modules/routes.ts"]
}
