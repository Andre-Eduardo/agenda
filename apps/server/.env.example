DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=agenda
DATABASE_HOST=localhost

DATABASE_URL="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}"

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Seleciona o provider de chat clínico ativo.
# Valores: mock (padrão, sem API key) | openrouter
AI_CHAT_PROVIDER=mock

# OpenRouter — https://openrouter.ai/keys
# Necessário apenas quando AI_CHAT_PROVIDER=openrouter
OPENROUTER_API_KEY=
# URL base da API do OpenRouter. Padrão: https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Modelo global no formato "provider/model" do OpenRouter.
# Usado pelo ChatModelProvider (fluxo legado). Cada agente pode ter seu próprio modelo via AGENT_*_MODEL.
# Exemplos: openai/gpt-4o | anthropic/claude-sonnet-4 | google/gemini-2.0-flash-001
OPENROUTER_MODEL=openai/gpt-4o
# Nome da aplicação — enviado como header X-Title ao OpenRouter
OPENROUTER_APP_NAME=App de Saúde
# URL da aplicação — enviado como header HTTP-Referer ao OpenRouter
OPENROUTER_APP_URL=https://seuapp.com.br

# ─── Embedding Provider ───────────────────────────────────────────────────────
# Desacoplado do chat — trocar AI_CHAT_PROVIDER nunca exige reindexação.
# Valores: mock (padrão, vetores aleatórios) | openai
AI_EMBEDDING_PROVIDER=mock

# OpenAI Embeddings — https://platform.openai.com/api-keys
# Necessário apenas quando AI_EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
# Modelo de embeddings. Padrão: text-embedding-3-small (1536 dims).
# Alternativas: text-embedding-3-large (3072 dims) | text-embedding-ada-002 (1536 dims)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Agent Registry — Modelos por especialidade ───────────────────────────────
# Modelo para cada agente no formato OpenRouter: provider/model
# Altere e reinicie para usar outro modelo sem migration.
AGENT_GP_MODEL=anthropic/claude-sonnet-4
AGENT_PSY_MODEL=anthropic/claude-sonnet-4
AGENT_PHYSIO_MODEL=anthropic/claude-sonnet-4
AGENT_SPEECH_MODEL=anthropic/claude-sonnet-4
AGENT_NUTRI_MODEL=anthropic/claude-sonnet-4
AGENT_OT_MODEL=anthropic/claude-sonnet-4
AGENT_NURSE_MODEL=anthropic/claude-sonnet-4

# ─── Agent Registry — Parâmetros opcionais por agente ────────────────────────
# Tokens máximos de resposta (padrão: 1500 para GP e PSY, 1200 para demais)
AGENT_GP_MAX_TOKENS=1500
AGENT_PSY_MAX_TOKENS=1500
AGENT_PHYSIO_MAX_TOKENS=1200
AGENT_SPEECH_MAX_TOKENS=1200
AGENT_NUTRI_MAX_TOKENS=1200
AGENT_OT_MAX_TOKENS=1200
AGENT_NURSE_MAX_TOKENS=1200

# Temperatura de geração (0.0 = determinístico, 1.0 = criativo)
AGENT_GP_TEMPERATURE=0.3
AGENT_PSY_TEMPERATURE=0.4
AGENT_PHYSIO_TEMPERATURE=0.3
AGENT_SPEECH_TEMPERATURE=0.3
AGENT_NUTRI_TEMPERATURE=0.3
AGENT_OT_TEMPERATURE=0.3
AGENT_NURSE_TEMPERATURE=0.3
