{
  "name": "@agenda-app/server",
  "private": true,
  "version": "0.0.0",
  "description": "The backend for the Agenda application",
  "scripts": {
    "typecheck": "tsc",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:integration": "cucumber-js",
    "start:database": "docker compose up -d postgres",
    "stop:environment": "docker compose down --volumes",
    "lint": "eslint . --ext ts,tsx --ignore-path .gitignore --report-unused-disable-directives --max-warnings 0",
    "postlint": "gherkin-lint",
    "lint:fix": "pnpm run eslint -- --fix",
    "start": "nest start",
    "prestart:dev": "pnpm run prisma:generate && pnpm run prisma:migrate",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:dev:full": "pnpm run start:database && prisma migrate dev && nest start --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main",
    "prisma:seed": "pnpm prisma db seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:create": "node scripts/create-migration.mjs",
    "postinstall": "node scripts/create-env.mjs && pnpm prisma:generate"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@nestjs/common": "^11.0.13",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.13",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.13",
    "@nestjs/swagger": "^11.1.1",
    "@prisma/client": "^6.11.0",
    "bignumber.js": "^9.2.0",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash.isequalwith": "^4.4.0",
    "nanoid": "^3.3.11",
    "nestjs-cls": "^5.4.2",
    "prisma": "^6.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0",
    "uuidv7": "^1.0.2",
    "validator": "^13.15.0",
    "winston": "^3.17.0",
    "xstate": "^5.19.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@ecxus/eslint-plugin": "^0.0.13",
    "@nestjs/cli": "^11.0.6",
    "@nestjs/schematics": "^11.0.3",
    "@nestjs/testing": "^11.0.13",
    "@swc-node/register": "^1.10.10",
    "@swc/jest": "^0.2.37",
    "@types/chai": "^4.3.20",
    "@types/chai-match-pattern": "^1.3.4",
    "@types/chai-subset": "^1.3.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/lodash.isequalwith": "^4.4.9",
    "@types/node": "^22.14.0",
    "@types/qs": "^6.14.0",
    "@types/sinon": "^17.0.4",
    "@types/supertest": "^6.0.3",
    "@types/validator": "^13.12.3",
    "chai": "^4.5.0",
    "chai-match-pattern": "^1.3.0",
    "chai-subset": "^1.6.0",
    "cross-env": "^7.0.3",
    "gherkin-lint": "^4.2.4",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "jest-mock-extended": "^3.0.7",
    "prompts": "^2.4.2",
    "qs": "^6.14.0",
    "sinon": "^20.0.0",
    "supertest": "^7.1.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "type-fest": "^4.39.1",
    "typescript": "^5.8.3",
    "yaml": "^2.7.1"
  }
}