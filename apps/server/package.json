{
  "name": "@agenda-app/server",
  "private": true,
  "version": "0.0.0",
  "description": "The backend for the Agenda application",
  "scripts": {
    "typecheck": "tsc",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:integration": "cucumber-js",
    "start:database": "docker compose up -d postgres",
    "stop:environment": "docker compose down --volumes",
    "lint": "eslint . --ext ts,tsx --ignore-path .gitignore --report-unused-disable-directives --max-warnings 0",
    "postlint": "gherkin-lint",
    "lint:fix": "pnpm run eslint -- --fix",
    "start": "nest start",
    "prestart:dev": "pnpm run prisma:generate && pnpm run prisma:migrate",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:dev:full": "pnpm run start:database && prisma migrate dev && nest start --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main",
    "prisma:seed": "pnpm prisma db seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:create": "node scripts/create-migration.mjs",
    "postinstall": "node scripts/create-env.mjs && pnpm prisma:generate"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.2.0",
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/platform-express": "^10.4.7",
    "@nestjs/swagger": "^8.0.7",
    "@prisma/client": "^6.3.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lodash.isequalwith": "^4.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.2",
    "uuidv7": "^1.0.2",
    "validator": "^13.12.0",
    "winston": "^3.16.0",
    "xstate": "^5.18.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^9.6.0",
    "@my-lint/eslint-plugin": "file:../../../myLint",
    "@nestjs/cli": "^10.4.7",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.7",
    "@swc-node/register": "^1.10.9",
    "@swc/jest": "^0.2.37",
    "@types/chai": "^4.3.16",
    "@types/chai-match-pattern": "^1.3.3",
    "@types/chai-subset": "^1.3.5",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/lodash.isequalwith": "^4.4.9",
    "@types/node": "^22.9.0",
    "@types/sinon": "^17.0.3",
    "@types/supertest": "^6.0.2",
    "@types/validator": "^13.12.2",
    "chai": "^4.4.1",
    "chai-match-pattern": "^1.3.0",
    "chai-subset": "^1.6.0",
    "cross-env": "^7.0.3",
    "gherkin-lint": "^4.2.4",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "jest-mock-extended": "^3.0.7",
    "prisma": "^6.3.0",
    "prompts": "^2.4.2",
    "sinon": "^19.0.2",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "type-fest": "^4.26.1",
    "typescript": "^5.6.3",
    "yaml": "^2.6.0"
  }
}