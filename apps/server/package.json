{
  "name": "@agenda-app/server",
  "private": true,
  "version": "0.0.0",
  "description": "The backend for the Agenda application",
  "scripts": {
    "typecheck": "tsc",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "test": "jest",
    "test:integration": "cucumber-js test/features/**/*.feature --retry 1",
    "start:database": "docker compose up -d postgres",
    "stop:environment": "docker compose down --volumes",
    "lint": "oxlint && oxfmt --check",
    "postlint": "gherkin-lint",
    "lint:fix": "oxlint --fix && oxfmt",
    "code-check": "oxlint --type-check && oxfmt --check && pnpm postlint",
    "start": "nest start",
    "prestart:dev": "pnpm run prisma:generate && pnpm run prisma:migrate",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:dev:full": "pnpm run start:database && pnpm run start:dev",
    "start:prod": "node dist/main",
    "openapi:generate": "nest start --entryFile generate-openapi",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:create": "node scripts/create-migration.mjs",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prepare-env": "node scripts/create-env.mjs",
    "postinstall": "pnpm prisma:generate",
    "ingest:knowledge": "ts-node --swc scripts/ingest-knowledge.ts",
    "validate:agent": "ts-node --swc scripts/validate-agent.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@aws-sdk/client-s3": "^3.987.0",
    "@aws-sdk/s3-request-presigner": "^3.987.0",
    "@nestjs/common": "^11.0.13",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.13",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.13",
    "@nestjs/platform-socket.io": "^11.0.13",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.1.1",
    "@nestjs/websockets": "^11.0.13",
    "@prisma/client": "^6.11.0",
    "bignumber.js": "^9.2.0",
    "compression": "^1.8.0",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "i18next": "^24.2.3",
    "jsonwebtoken": "^9.0.2",
    "lodash.isequalwith": "^4.4.0",
    "mime-types": "^3.0.2",
    "mqtt": "^5.15.0",
    "multer": "^2.0.2",
    "nanoid": "^3.3.11",
    "nestjs-cls": "^5.4.2",
    "prisma": "^6.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "type-fest": "^4.39.1",
    "uuid": "^11.1.0",
    "uuidv7": "^1.0.2",
    "validator": "^13.15.0",
    "winston": "^3.17.0",
    "xstate": "^5.19.2",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@eslint/compat": "^2.0.3",
    "@nestjs/cli": "^11.0.6",
    "@nestjs/schematics": "^11.0.3",
    "@nestjs/testing": "^11.0.13",
    "@swc-node/register": "^1.10.10",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.26",
    "@swc/jest": "^0.2.37",
    "@types/chai": "^4.3.20",
    "@types/chai-match-pattern": "^1.3.4",
    "@types/chai-subset": "^1.3.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/lodash.isequalwith": "^4.4.9",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.14.0",
    "@types/qs": "^6.14.0",
    "@types/sinon": "^17.0.4",
    "@types/supertest": "^6.0.3",
    "@types/validator": "^13.12.3",
    "chai": "^4.5.0",
    "chai-match-pattern": "^1.3.0",
    "chai-subset": "^1.6.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "gherkin-lint": "^4.2.4",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "jest-mock-extended": "^3.0.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.18.0",
    "prompts": "^2.4.2",
    "qs": "^6.14.0",
    "sinon": "^20.0.0",
    "supertest": "^7.1.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "yaml": "^2.7.1"
  }
}
