{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["openapi.json"],
  "bracketSpacing": false,
  "endOfLine": "lf",
  "printWidth": 120,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 4,
  "trailingComma": "es5",
  "sortImports": {
    "newlinesBetween": false,
    "internalPattern": ["@application/", "@domain/", "@infrastructure/"],
    "groups": [
      "builtin",
      "external",
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "style",
      "unknown"
    ]
  },
  "overrides": [
    {
      "files": ["*.json", "*.yml"],
      "options": {
        "printWidth": 100,
        "tabWidth": 2,
        "singleQuote": false
      }
    }
  ]
}
