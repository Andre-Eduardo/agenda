{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "declaration": false,
    "paths": {
      "@application/*": ["./src/application/*"],
      "@domain/*": ["./src/domain/*"],
      "@infrastructure/*": ["./src/infrastructure/*"]
    }
  },
  "exclude": [
    "./node_modules",
    "./dist",
    "./test",
    "./*.config.ts",
    "./src/**/*.test.ts",
    "./prisma"
  ]
}
