generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, pgvector(map: "vector")]
}

// ─────────────────────────────────────────────────────────────────────────────
// 1. IDENTIDADE & AUTENTICAÇÃO
// ─────────────────────────────────────────────────────────────────────────────

/// User é apenas autenticação. Toda atuação dentro de uma clínica passa por ClinicMember.
/// Decisão: um User opera em apenas uma clínica. Se a mesma pessoa atua em duas clínicas,
/// ela tem dois logins distintos.
model User {
  id         String     @id(map: "user_pk") @db.Uuid
  username   String     @unique @db.Citext()
  email      String?    @unique @db.Citext()
  name       String     @map("name")
  password   String
  phone      String?
  globalRole GlobalRole @map("global_role")
  createdAt  DateTime   @map("created_at")
  updatedAt  DateTime   @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")

  members ClinicMember[]

  @@map("user")
}

enum GlobalRole {
  SUPER_ADMIN
  OWNER
  NONE

  @@map("global_role")
}

enum Gender {
  MALE
  FEMALE
  OTHER

  @@map("gender")
}

enum PersonType {
  NATURAL
  LEGAL

  @@map("person_type")
}

/// Person continua como entidade reutilizável de dados pessoais para Patient.
/// Antes também era usada por Professional — esses dados agora vivem em
/// User (login/contato) + ClinicMember (atuação) + Professional (regulatório).
model Person {
  id         String     @id(map: "person_pk") @db.Uuid
  name       String
  documentId String     @map("document_id")
  phone      String?
  gender     Gender?
  personType PersonType @map("person_type")
  createdAt  DateTime   @map("created_at")
  updatedAt  DateTime   @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")

  patients Patient[]

  @@map("person")
}

// ─────────────────────────────────────────────────────────────────────────────
// 2. CLÍNICA — TENANT RAIZ
// ─────────────────────────────────────────────────────────────────────────────

/// Toda entidade de dado clínico pertence a uma Clinic. Boundary de isolamento:
/// nenhum dado vaza entre clínicas. Para profissional autônomo, uma Clinic é criada
/// automaticamente com isPersonalClinic = true (front esconde menus de equipe).
model Clinic {
  id               String     @id(map: "clinic_pk") @db.Uuid
  name             String
  documentId       String?    @map("document_id")
  phone            String?
  email            String?    @db.Citext()
  /// true = autônomo usando o sistema sem clínica real. Front simplifica UI.
  isPersonalClinic Boolean    @default(false) @map("is_personal_clinic")
  /// Endereço da clínica
  street           String?
  number           String?
  complement       String?
  neighborhood     String?
  city             String?
  state            String?
  zipCode          String?    @map("zip_code")
  country          String?    @default("BR")
  /// URL da logo da clínica
  logoUrl          String?    @map("logo_url")
  /// Especialidades atendidas pela clínica
  clinicSpecialties Specialty[] @map("clinic_specialties")
  createdAt        DateTime   @map("created_at")
  updatedAt        DateTime   @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  members             ClinicMember[]
  patients            Patient[]
  patientAccesses     ClinicPatientAccess[]
  documentPermissions DocumentPermission[]
  appointments        Appointment[]
  records             Record[]
  files               File[]
  importedDocuments   ImportedDocument[]
  clinicalProfiles    ClinicalProfile[]
  patientAlerts       PatientAlert[]
  formTemplates       FormTemplate[]
  patientForms        PatientForm[]
  chatSessions        PatientChatSession[]
  contextSnapshots    PatientContextSnapshot[]
  contextChunks       PatientContextChunk[]
  chatInteractionLogs ClinicalChatInteractionLog[]
  events              Event[]
  agentProposals      AgentProposal[]
  knowledgeChunks     KnowledgeChunk[]
  patientAddresses    PatientAddress[]
  insurancePlans      InsurancePlan[]

  @@map("clinic")
}

// ─────────────────────────────────────────────────────────────────────────────
// 3. MEMBRO DA CLÍNICA — ATOR CENTRAL
// ─────────────────────────────────────────────────────────────────────────────

/// Roles definem o TETO de capacidade. As permissões granulares por paciente
/// e por documento vivem em ClinicPatientAccess e DocumentPermission.
enum ClinicMemberRole {
  /// Acesso total. Gerencia membros e permissões. Único membro inicial em isPersonalClinic.
  OWNER
  /// Gerencia membros (exceto OWNER) e permissões. Não pode se auto-promover a OWNER.
  ADMIN
  /// Profissional de saúde. Cria prontuários, evoluções. Exige Professional vinculado.
  PROFESSIONAL
  /// Cadastra pacientes, agenda, faz upload. Acesso a dados clínicos depende de permissão.
  SECRETARY
  /// Somente leitura onde tiver permissão explícita.
  VIEWER

  @@map("clinic_member_role")
}

/// Pivô central do sistema. Toda ação registra o ClinicMember responsável
/// via createdByMemberId para auditoria.
///
/// Quando role = PROFESSIONAL, existe um Professional 1:1 com dados regulatórios.
/// Para SECRETARY, ADMIN, VIEWER, professional é null.
///
/// Absorveu o antigo ProfessionalConfig (campo color) e o vínculo com User
/// que antes ficava em Professional.
model ClinicMember {
  id                String           @id(map: "clinic_member_pk") @db.Uuid
  clinicId          String           @map("clinic_id") @db.Uuid
  clinic            Clinic           @relation(fields: [clinicId], references: [id])
  userId            String           @map("user_id") @db.Uuid
  user              User             @relation(fields: [userId], references: [id])
  role              ClinicMemberRole
  /// Como o membro aparece na UI da clínica (ex: "Dr. João Silva")
  displayName       String?          @map("display_name")
  /// Cor na agenda (substitui ProfessionalConfig.color)
  color             String?
  isActive          Boolean          @default(true) @map("is_active")
  /// Auditoria de onboarding. Null para o OWNER inicial da clínica.
  invitedByMemberId String?          @map("invited_by_member_id") @db.Uuid
  invitedBy         ClinicMember?    @relation("MemberInvites", fields: [invitedByMemberId], references: [id])
  invitedMembers    ClinicMember[]   @relation("MemberInvites")

  createdAt DateTime  @map("created_at")
  updatedAt DateTime  @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Extensão profissional (apenas quando role = PROFESSIONAL)
  professional Professional?

  // Acesso e configurações pessoais
  patientAccesses            ClinicPatientAccess[]
  grantedDocumentPermissions DocumentPermission[]  @relation("PermissionGrantedTo")
  permissionsAuthored        DocumentPermission[]  @relation("PermissionGrantedBy")
  workingHours               WorkingHours[]
  blocks                     MemberBlock[]

  // Auditoria — quem criou cada coisa
  createdAppointments      Appointment[]            @relation("AppointmentCreatedBy")
  attendedAppointments     Appointment[]            @relation("AppointmentAttendedBy")
  createdRecords           Record[]                 @relation("RecordCreatedBy")
  createdFiles             File[]
  createdImportedDocuments ImportedDocument[]
  createdClinicalProfiles  ClinicalProfile[]        @relation("ClinicalProfileCreatedBy")
  createdPatientAlerts     PatientAlert[]
  createdFormTemplates     FormTemplate[]
  createdPatientForms      PatientForm[]            @relation("PatientFormCreatedBy")
  chatSessions             PatientChatSession[]
  contextSnapshots         PatientContextSnapshot[]
  events                   Event[]
  createdAgentProposals    AgentProposal[]          @relation("AgentProposalCreatedBy")

  @@unique([clinicId, userId], name: "clinic_member_clinic_user_unique")
  @@index([clinicId], name: "clinic_member_clinic_idx")
  @@index([userId], name: "clinic_member_user_idx")
  @@map("clinic_member")
}

// ─────────────────────────────────────────────────────────────────────────────
// 4. PROFISSIONAL DE SAÚDE — EXTENSÃO 1:1 DO MEMBRO
// ─────────────────────────────────────────────────────────────────────────────

enum Specialty {
  PSICOLOGIA
  MEDICINA
  FISIOTERAPIA
  FONOAUDIOLOGIA
  NUTRICAO
  TERAPIA_OCUPACIONAL
  ENFERMAGEM
  OUTROS

  @@map("specialty")
}

/// Dados regulatórios e clínicos do profissional de saúde.
/// Existe apenas quando ClinicMember.role = PROFESSIONAL.
///
/// MUDANÇAS:
/// - Não tem mais relação direta com User (vai via ClinicMember)
/// - Não tem mais relação direta com Person (dados pessoais ficam no User)
/// - Não tem mais ProfessionalConfig (color migrou para ClinicMember)
/// - Aparece nas relações de "responsabilidade clínica", separado de "quem digitou"
model Professional {
  id                  String       @id(map: "professional_pk") @db.Uuid
  clinicMemberId      String       @unique @map("clinic_member_id") @db.Uuid
  clinicMember        ClinicMember @relation(fields: [clinicMemberId], references: [id])
  registrationNumber  String?      @map("registration_number")
  specialty           String?
  specialtyNormalized Specialty?   @map("specialty_normalized")
  createdAt           DateTime     @map("created_at")
  updatedAt           DateTime     @map("updated_at")
  deletedAt           DateTime?    @map("deleted_at")

  // Relações como profissional clinicamente responsável (≠ quem digitou)
  responsibleRecords          Record[]          @relation("RecordResponsibleProfessional")
  responsibleClinicalProfiles ClinicalProfile[] @relation("ClinicalProfileResponsibleProfessional")
  responsiblePatientForms     PatientForm[]     @relation("PatientFormResponsibleProfessional")

  @@map("professional")
}

// ─────────────────────────────────────────────────────────────────────────────
// 5. PERMISSÕES — ACESSO A PACIENTE E A DOCUMENTO
// ─────────────────────────────────────────────────────────────────────────────

enum PatientAccessLevel {
  /// Acesso total ao paciente: ver dados, criar e editar registros.
  FULL
  /// Pode ver dados clínicos do paciente, mas não pode criar/editar.
  READ_ONLY
  /// Pode cadastrar/atualizar dados básicos e fazer upload, mas não pode ler
  /// documentos clínicos. Caso típico: secretária durante o cadastro inicial.
  REGISTER_ONLY
  /// Sem acesso. Usado para revogação explícita.
  NONE

  @@map("patient_access_level")
}

/// Acesso de um membro a um paciente dentro da clínica.
/// Resolução de permissão (em ordem):
///   1. Role no ClinicMember (teto funcional)
///   2. ClinicPatientAccess (acesso ao paciente)
///   3. DocumentPermission (override por documento, se existir)
///
/// OWNER e ADMIN ignoram esse check (acesso total por definição).
/// Pode ser criado automaticamente ao primeiro contato (Appointment, Record)
/// ou explicitamente pelo OWNER/ADMIN.
model ClinicPatientAccess {
  id          String             @id(map: "clinic_patient_access_pk") @db.Uuid
  clinicId    String             @map("clinic_id") @db.Uuid
  clinic      Clinic             @relation(fields: [clinicId], references: [id])
  memberId    String             @map("member_id") @db.Uuid
  member      ClinicMember       @relation(fields: [memberId], references: [id])
  patientId   String             @map("patient_id") @db.Uuid
  patient     Patient            @relation(fields: [patientId], references: [id])
  accessLevel PatientAccessLevel @map("access_level")
  /// Justificativa opcional registrada pelo gestor ao conceder/restringir.
  reason      String?
  createdAt   DateTime           @map("created_at")
  updatedAt   DateTime           @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  @@unique([memberId, patientId], name: "clinic_patient_access_member_patient_unique")
  @@index([clinicId], name: "clinic_patient_access_clinic_idx")
  @@index([patientId], name: "clinic_patient_access_patient_idx")
  @@map("clinic_patient_access")
}

/// Tipo de entidade alvo de uma permissão por documento.
/// Modelo polimórfico: a FK não é formal (sem relation no Prisma) — a integridade
/// é garantida pela aplicação. Vantagem: uma única tabela cobre todos os tipos
/// de documento sem explosão de JOINs.
enum DocumentEntityType {
  RECORD
  FILE
  IMPORTED_DOCUMENT
  PATIENT_FORM
  CLINICAL_PROFILE
  PATIENT_ALERT

  @@map("document_entity_type")
}

/// Permissão granular por documento. Sobrescreve ClinicPatientAccess.
///
/// Exemplos de uso:
/// - Secretária tem acesso REGISTER_ONLY ao paciente, mas a clínica concede
///   canView=true em FILEs específicos (exames que ela mesma cadastrou).
/// - Médico A criou um Record. Médico B tem FULL no paciente, mas a clínica
///   restringiu canView=false neste Record específico.
///
/// Quando NÃO existe registro para (membro, documento), o acesso herda de
/// ClinicPatientAccess. Quando existe, prevalece o que está aqui.
model DocumentPermission {
  id            String             @id(map: "document_permission_pk") @db.Uuid
  clinicId      String             @map("clinic_id") @db.Uuid
  clinic        Clinic             @relation(fields: [clinicId], references: [id])
  memberId      String             @map("member_id") @db.Uuid
  member        ClinicMember       @relation("PermissionGrantedTo", fields: [memberId], references: [id])
  entityType    DocumentEntityType @map("entity_type")
  entityId      String             @map("entity_id") @db.Uuid
  canView       Boolean            @map("can_view")
  /// Quem concedeu/revogou (auditoria de mudanças de permissão)
  grantedByMemberId String?        @map("granted_by_member_id") @db.Uuid
  grantedBy     ClinicMember?      @relation("PermissionGrantedBy", fields: [grantedByMemberId], references: [id])
  reason        String?
  createdAt     DateTime           @map("created_at")
  updatedAt     DateTime           @map("updated_at")

  @@unique([memberId, entityType, entityId], name: "document_permission_member_entity_unique")
  @@index([entityType, entityId], name: "document_permission_entity_idx")
  @@index([clinicId], name: "document_permission_clinic_idx")
  @@map("document_permission")
}

// ─────────────────────────────────────────────────────────────────────────────
// 6. PACIENTE
// ─────────────────────────────────────────────────────────────────────────────

/// Patient agora pertence à Clinic, não ao Professional.
/// MUDANÇAS:
/// - professionalId removido (acesso vem via ClinicPatientAccess)
/// - clinicId adicionado (boundary de tenant)
/// - unique constraint mudou: era (documentId, professionalId), agora (documentId, clinicId)
model Patient {
  id                    String        @id(map: "patient_pk") @db.Uuid
  person                Person        @relation(fields: [id], references: [id], onDelete: Cascade)
  clinicId              String        @map("clinic_id") @db.Uuid
  clinic                Clinic        @relation(fields: [clinicId], references: [id])
  documentId            String        @map("document_id") @db.Citext()
  birthDate             DateTime?     @map("birth_date")
  email                 String?       @db.Citext()
  emergencyContactName  String?       @map("emergency_contact_name")
  emergencyContactPhone String?       @map("emergency_contact_phone")
  /// Convênio/plano de saúde
  insurancePlanId       String?       @map("insurance_plan_id") @db.Uuid
  insurancePlan         InsurancePlan? @relation(fields: [insurancePlanId], references: [id])
  insuranceCardNumber   String?       @map("insurance_card_number")
  insuranceValidUntil   DateTime?     @map("insurance_valid_until")
  createdAt             DateTime      @map("created_at")
  updatedAt             DateTime      @map("updated_at")
  deletedAt             DateTime?     @map("deleted_at")

  accesses          ClinicPatientAccess[]
  appointments      Appointment[]
  records           Record[]
  clinicalProfile   ClinicalProfile?
  alerts            PatientAlert[]
  patientFiles      File[]
  importedDocuments ImportedDocument[]
  patientForms      PatientForm[]
  chatSessions      PatientChatSession[]
  contextSnapshots  PatientContextSnapshot[]
  contextChunks     PatientContextChunk[]
  address           PatientAddress?

  @@unique([documentId, clinicId], name: "patient_document_clinic_unique")
  @@index([clinicId], name: "patient_clinic_idx")
  @@map("patient")
}

/// Endereço do paciente — separado de Person para manter Person reutilizável.
/// Relação 1:1 com Patient; escopo de tenant via clinicId.
model PatientAddress {
  id           String  @id(map: "patient_address_pk") @db.Uuid
  patientId    String  @unique @map("patient_id") @db.Uuid
  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinicId     String  @map("clinic_id") @db.Uuid
  clinic       Clinic  @relation(fields: [clinicId], references: [id])
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String? @map("zip_code")
  country      String? @default("BR")
  createdAt    DateTime @map("created_at")
  updatedAt    DateTime @map("updated_at")

  @@index([clinicId], name: "patient_address_clinic_idx")
  @@map("patient_address")
}

/// Plano de saúde/convênio da clínica.
/// Cadastrado por clínica (não global no MVP).
model InsurancePlan {
  id        String    @id(map: "insurance_plan_pk") @db.Uuid
  clinicId  String    @map("clinic_id") @db.Uuid
  clinic    Clinic    @relation(fields: [clinicId], references: [id])
  name      String
  code      String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @map("created_at")
  updatedAt DateTime  @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  patients  Patient[]

  @@index([clinicId], name: "insurance_plan_clinic_idx")
  @@map("insurance_plan")
}

// ─────────────────────────────────────────────────────────────────────────────
// 7. ENUMS CLÍNICOS (inalterados em relação ao schema original)
// ─────────────────────────────────────────────────────────────────────────────

enum EvolutionTemplateType {
  SOAP
  DAP

  @@map("evolution_template_type")
}

enum RecordSource {
  MANUAL
  IMPORT

  @@map("record_source")
}

enum ImportStatus {
  UPLOADED
  QUALITY_CHECKED
  PREPROCESSED
  OCR_DONE
  NORMALIZED
  CLASSIFIED
  AI_STRUCTURED
  READY_FOR_REVIEW
  APPROVED
  REJECTED
  FAILED

  @@map("import_status")
}

enum AttendanceType {
  FIRST_VISIT
  FOLLOW_UP
  EVALUATION
  PROCEDURE
  TELEMEDICINE
  INTERCURRENCE

  @@map("attendance_type")
}

enum ClinicalStatusTag {
  STABLE
  IMPROVING
  WORSENING
  UNCHANGED
  UNDER_OBSERVATION

  @@map("clinical_status_tag")
}

enum ConductTag {
  GUIDANCE
  PRESCRIPTION
  EXAM_REQUESTED
  REFERRAL
  FOLLOW_UP_SCHEDULED
  THERAPY_ADJUSTMENT

  @@map("conduct_tag")
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH

  @@map("alert_severity")
}

enum FormStatus {
  DRAFT
  PUBLISHED
  DEPRECATED

  @@map("form_status")
}

enum FormResponseStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("form_response_status")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW

  @@map("appointment_status")
}

enum AppointmentType {
  FIRST_VISIT
  RETURN
  WALK_IN
  TELEMEDICINE
  PROCEDURE

  @@map("appointment_type")
}

// ─────────────────────────────────────────────────────────────────────────────
// 8. AGENDA
// ─────────────────────────────────────────────────────────────────────────────

/// MUDANÇAS:
/// - clinicId adicionado
/// - professionalId substituído por attendedByMemberId (membro que atende)
///   + createdByMemberId (membro que agendou — pode ser secretária)
model Appointment {
  id                  String            @id(map: "appointment_pk") @db.Uuid
  clinicId            String            @map("clinic_id") @db.Uuid
  clinic              Clinic            @relation(fields: [clinicId], references: [id])
  /// Membro que atende (deve ter role PROFESSIONAL)
  attendedByMemberId  String            @map("attended_by_member_id") @db.Uuid
  attendedBy          ClinicMember      @relation("AppointmentAttendedBy", fields: [attendedByMemberId], references: [id])
  /// Membro que registrou o agendamento (pode ser secretária ou o próprio profissional)
  createdByMemberId   String            @map("created_by_member_id") @db.Uuid
  createdBy           ClinicMember      @relation("AppointmentCreatedBy", fields: [createdByMemberId], references: [id])
  patientId           String            @map("patient_id") @db.Uuid
  patient             Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  startAt             DateTime          @map("start_at")
  endAt               DateTime          @map("end_at")
  durationMinutes     Int               @map("duration_minutes")
  type                AppointmentType   @map("type")
  status              AppointmentStatus @map("status")
  canceledAt          DateTime?         @map("canceled_at")
  canceledReason      String?           @map("canceled_reason")
  note                String?
  createdAt           DateTime          @map("created_at")
  updatedAt           DateTime          @map("updated_at")
  deletedAt           DateTime?         @map("deleted_at")
  records             Record[]

  @@index([clinicId], name: "appointment_clinic_idx")
  @@index([attendedByMemberId], name: "appointment_attended_by_idx")
  @@map("appointment")
}

/// MUDANÇA: professionalId → clinicMemberId (apenas membros PROFESSIONAL devem ter)
model WorkingHours {
  id             String       @id(map: "working_hours_pk") @db.Uuid
  clinicMemberId String       @map("clinic_member_id") @db.Uuid
  clinicMember   ClinicMember @relation(fields: [clinicMemberId], references: [id], onDelete: Cascade)
  dayOfWeek      Int          @map("day_of_week")
  startTime      String       @map("start_time")
  endTime        String       @map("end_time")
  slotDuration   Int          @map("slot_duration")
  active         Boolean      @default(true)
  createdAt      DateTime     @map("created_at")
  updatedAt      DateTime     @map("updated_at")

  @@map("working_hours")
}

/// MUDANÇA: ProfessionalBlock renomeado para MemberBlock (semanticamente mais
/// correto agora que o ator é o membro). professionalId → clinicMemberId.
model MemberBlock {
  id             String       @id(map: "member_block_pk") @db.Uuid
  clinicMemberId String       @map("clinic_member_id") @db.Uuid
  clinicMember   ClinicMember @relation(fields: [clinicMemberId], references: [id], onDelete: Cascade)
  startAt        DateTime     @map("start_at")
  endAt          DateTime     @map("end_at")
  reason         String?
  createdAt      DateTime     @map("created_at")
  updatedAt      DateTime     @map("updated_at")

  @@map("member_block")
}

// ─────────────────────────────────────────────────────────────────────────────
// 9. PRONTUÁRIO E DOCUMENTOS
// ─────────────────────────────────────────────────────────────────────────────

/// MUDANÇAS:
/// - clinicId adicionado
/// - professionalId substituído por:
///     * createdByMemberId (quem digitou — auditoria)
///     * responsibleProfessionalId (profissional clinicamente responsável)
///   Em geral são iguais, mas podem divergir (ex: secretária digitando dictado).
model Record {
  id                       String                 @id(map: "record_pk") @db.Uuid
  clinicId                 String                 @map("clinic_id") @db.Uuid
  clinic                   Clinic                 @relation(fields: [clinicId], references: [id])
  createdByMemberId        String                 @map("created_by_member_id") @db.Uuid
  createdBy                ClinicMember           @relation("RecordCreatedBy", fields: [createdByMemberId], references: [id])
  responsibleProfessionalId String                @map("responsible_professional_id") @db.Uuid
  responsibleProfessional  Professional           @relation("RecordResponsibleProfessional", fields: [responsibleProfessionalId], references: [id])
  patientId                String                 @map("patient_id") @db.Uuid
  patient                  Patient                @relation(fields: [patientId], references: [id])
  description              String?
  templateType             EvolutionTemplateType? @map("template_type")
  title                    String?
  attendanceType           AttendanceType?        @map("attendance_type")
  clinicalStatus           ClinicalStatusTag?     @map("clinical_status")
  conductTags              ConductTag[]           @map("conduct_tags")
  subjective               String?
  objective                String?
  assessment               String?
  plan                     String?
  freeNotes                String?                @map("free_notes")
  eventDate                DateTime?              @map("event_date")
  appointmentId            String?                @map("appointment_id") @db.Uuid
  appointment              Appointment?           @relation(fields: [appointmentId], references: [id])
  files                    File[]

  source             RecordSource      @default(MANUAL) @map("source")
  importedDocumentId String?           @map("imported_document_id") @db.Uuid
  importedDocument   ImportedDocument? @relation(fields: [importedDocumentId], references: [id])
  wasHumanEdited     Boolean           @default(false) @map("was_human_edited")

  patientFormId String?      @unique @map("patient_form_id") @db.Uuid
  patientForm   PatientForm? @relation("RecordPatientForm", fields: [patientFormId], references: [id])

  createdAt DateTime  @map("created_at")
  updatedAt DateTime  @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([clinicId], name: "record_clinic_idx")
  @@index([patientId], name: "record_patient_idx")
  @@map("record")
}

