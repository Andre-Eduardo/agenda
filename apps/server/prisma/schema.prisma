  updatedAt DateTime @map("updated_at")

  @@index([clinicId], name: "clinical_chat_interaction_log_clinic_idx")
  @@index([sessionId], name: "clinical_chat_interaction_log_session_idx")
  @@map("clinical_chat_interaction_log")
}

// ─────────────────────────────────────────────────────────────────────────────
// 13. KNOWLEDGE BASE — RAG GLOBAL/POR CLÍNICA
// ─────────────────────────────────────────────────────────────────────────────

/// Knowledge chunks usados pelo RAG do agente clínico.
/// `clinicId` null = chunk global compartilhado entre todas as clínicas.
/// `clinicId` preenchido = chunk privado de uma clínica.
model KnowledgeChunk {
  id          String     @id(map: "knowledge_chunk_pk") @db.Uuid
  /// null = chunk global; preenchido = scoped para uma clínica
  clinicId    String?    @map("clinic_id") @db.Uuid
  clinic      Clinic?    @relation(fields: [clinicId], references: [id])
  specialty   Specialty? @map("specialty")
  /// "protocolo" | "cid" | "faq" | "manual" | "diretriz"
  category    String     @map("category")
  content     String     @db.Text
  /// {title, section, tags, originalFormat}
  metadata    Json?      @db.JsonB
  sourceFile  String?    @map("source_file")
  sourcePage  Int?       @map("source_page")
  /// Embedding vetorial para busca semântica via pgvector.
  /// Gerado pelo EmbeddingProvider (nunca pelo ChatProvider).
  embedding   Unsupported("vector(1536)")?
  /// Hash SHA-256 do content — detecta mudanças para re-indexação
  contentHash String     @unique @map("content_hash")

  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")

  @@index([clinicId], name: "knowledge_chunk_clinic_idx")
  @@index([specialty], name: "knowledge_chunk_specialty_idx")
  @@index([category], name: "knowledge_chunk_category_idx")
  // Nota: índice HNSW criado via migration SQL (Prisma v6 não suporta sintaxe pgvector).
  @@map("knowledge_chunk")
}

// ─────────────────────────────────────────────────────────────────────────────
// 14. AGENT PROPOSAL — MUTAÇÕES PROPOSTAS PELO AGENTE IA
// ─────────────────────────────────────────────────────────────────────────────

enum AgentProposalType {
  APPOINTMENT
  APPOINTMENT_CANCEL
  APPOINTMENT_RESCHEDULE
  PATIENT_ALERT

  @@map("agent_proposal_type")
}

enum AgentProposalStatus {
  PENDING
  CONFIRMED
  REJECTED
  EXPIRED

  @@map("agent_proposal_status")
}

/// A proposal created by the AI agent that requires human confirmation before executing.
/// Mutations never write to domain entities directly — they always go through AgentProposal first.
///
/// MUDANÇA: professionalId removido. Agora rastreia clinicId (tenant) +
/// createdByMemberId (autor da proposta — sempre o ClinicMember dono da sessão).
model AgentProposal {
  id                 String              @id(map: "agent_proposal_pk") @db.Uuid
  clinicId           String              @map("clinic_id") @db.Uuid
  clinic             Clinic              @relation(fields: [clinicId], references: [id])
  createdByMemberId  String              @map("created_by_member_id") @db.Uuid
  createdByMember    ClinicMember        @relation("AgentProposalCreatedBy", fields: [createdByMemberId], references: [id])
  sessionId          String?             @map("session_id") @db.Uuid
  messageId          String?             @map("message_id") @db.Uuid
  patientId          String?             @map("patient_id") @db.Uuid
  proposalType       AgentProposalType   @map("type")
  status             AgentProposalStatus @default(PENDING) @map("status")
  /// Payload for creating the target entity when confirmed
  payload            Json                @db.JsonB
  /// Simplified preview for frontend rendering
  preview            Json                @db.JsonB
  rationale          String?             @db.Text
  confidence         Float?
  /// ID of the entity created upon confirmation
  resultEntityId     String?             @map("result_entity_id") @db.Uuid
  expiresAt          DateTime?           @map("expires_at")
  confirmedAt        DateTime?           @map("confirmed_at")
  confirmedBy        String?             @map("confirmed_by") @db.Uuid
  rejectedAt         DateTime?           @map("rejected_at")
  rejectionReason    String?             @map("rejection_reason") @db.Text

  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")

  @@index([clinicId, status], name: "agent_proposal_clinic_status_idx")
  @@index([createdByMemberId], name: "agent_proposal_created_by_member_idx")
  @@index([patientId], name: "agent_proposal_patient_idx")
  @@map("agent_proposal")
}