generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, pgvector(map: "vector")]
}

model User {
  id         String     @id(map: "user_pk") @db.Uuid
  username   String     @unique @db.Citext()
  email      String?    @unique @db.Citext()
  name       String     @map("name")
  password   String
  phone      String?
  globalRole GlobalRole @map("global_role")
  createdAt  DateTime   @map("created_at")
  updatedAt  DateTime   @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")

  professionals Professional[]

  @@map("user")
}

enum GlobalRole {
  SUPER_ADMIN
  OWNER
  NONE

  @@map("global_role")
}

enum Gender {
  MALE
  FEMALE
  OTHER

  @@map("gender")
}

enum PersonProfile {
  PROFESSIONAL
  PATIENT

  @@map("person_profile")
}

enum PersonType {
  NATURAL
  LEGAL

  @@map("person_type")
}

model Person {
  id           String        @id(map: "person_pk") @db.Uuid
  name         String
  documentId   String        @map("document_id")
  phone        String?
  gender       Gender?
  personType   PersonType    @map("person_type")
  createdAt    DateTime      @map("created_at")
  updatedAt    DateTime      @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")
  professional Professional?
  patients     Patient[]

  @@unique([documentId], name: "person_document_id_key")
  @@map("person")
}

// 🔑 Professional com config 1:1 (igual Company)
model Professional {
  id        String             @id(map: "professional_pk") @db.Uuid
  personId  String             @unique @map("person_id") @db.Uuid
  person    Person             @relation(fields: [personId], references: [id])
  configId  String             @unique(map: "professional_config_id_key") @map("config_id") @db.Uuid
  config    ProfessionalConfig @relation(references: [id], fields: [configId])
  userId    String             @map("user_id") @db.Uuid
  user      User               @relation(fields: [userId], references: [id])
  specialty           String?
  specialtyNormalized Specialty? @map("specialty_normalized")
  createdAt           DateTime   @map("created_at")
  updatedAt           DateTime   @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")

  appointments       Appointment[]
  records            Record[]
  patients           Patient[]
  workingHours       WorkingHours[]
  professionalBlocks ProfessionalBlock[]
  clinicalProfiles   ClinicalProfile[]
  patientAlerts      PatientAlert[]
  ImportedDocument   ImportedDocument[]
  formTemplates      FormTemplate[]
  patientForms       PatientForm[]
  chatSessions       PatientChatSession[]
  contextSnapshots   PatientContextSnapshot[]

  @@map("professional")
}

model ProfessionalConfig {
  id        String    @id(map: "professional_config_pk") @db.Uuid
  color     String?
  createdAt DateTime  @map("created_at")
  updatedAt DateTime  @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  professional Professional?

  @@map("professional_config")
}

model Patient {
  id                    String             @id(map: "patient_pk") @db.Uuid
  person                Person             @relation(fields: [id], references: [id], onDelete: Cascade)
  documentId            String             @map("document_id") @db.Citext()
  birthDate             DateTime?          @map("birth_date")
  email                 String?            @db.Citext()
  emergencyContactName  String?            @map("emergency_contact_name")
  emergencyContactPhone String?            @map("emergency_contact_phone")
  createdAt             DateTime           @map("created_at")
  updatedAt             DateTime           @map("updated_at")
  deletedAt             DateTime?          @map("deleted_at")
  appointments          Appointment[]
  records               Record[]
  professional          Professional?      @relation(fields: [professionalId], references: [id])
  professionalId        String?            @db.Uuid
  clinicalProfile       ClinicalProfile?
  alerts                PatientAlert[]
  patientFiles          File[]
  ImportedDocument      ImportedDocument[]
  patientForms          PatientForm[]
  chatSessions          PatientChatSession[]
  contextSnapshots      PatientContextSnapshot[]
  contextChunks         PatientContextChunk[]

  @@unique([documentId], name: "patient_document_id_key")
  @@map("patient")
}

enum EvolutionTemplateType {
  SOAP
  DAP

  @@map("evolution_template_type")
}

enum RecordSource {
  MANUAL
  IMPORT

  @@map("record_source")
}

enum ImportStatus {
  UPLOADED
  QUALITY_CHECKED
  PREPROCESSED
  OCR_DONE
  NORMALIZED
  CLASSIFIED
  AI_STRUCTURED
  READY_FOR_REVIEW
  APPROVED
  REJECTED
  FAILED

  @@map("import_status")
}

enum AttendanceType {
  FIRST_VISIT
  FOLLOW_UP
  EVALUATION
  PROCEDURE
  TELEMEDICINE
  INTERCURRENCE

  @@map("attendance_type")
}

enum ClinicalStatusTag {
  STABLE
  IMPROVING
  WORSENING
  UNCHANGED
  UNDER_OBSERVATION

  @@map("clinical_status_tag")
}

enum ConductTag {
  GUIDANCE
  PRESCRIPTION
  EXAM_REQUESTED
  REFERRAL
  FOLLOW_UP_SCHEDULED
  THERAPY_ADJUSTMENT

  @@map("conduct_tag")
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH

  @@map("alert_severity")
}

enum Specialty {
  PSICOLOGIA
  MEDICINA
  FISIOTERAPIA
  FONOAUDIOLOGIA
  NUTRICAO
  TERAPIA_OCUPACIONAL
  ENFERMAGEM
  OUTROS

  @@map("specialty")
}

enum FormStatus {
  DRAFT
  PUBLISHED
  DEPRECATED

  @@map("form_status")
}

enum FormResponseStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("form_response_status")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW

  @@map("appointment_status")
}

enum AppointmentType {
  FIRST_VISIT
  RETURN
  WALK_IN
  TELEMEDICINE
  PROCEDURE

  @@map("appointment_type")
}

model Appointment {
  id              String            @id(map: "appointment_pk") @db.Uuid
  professionalId  String            @map("professional_id") @db.Uuid
  professional    Professional      @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  patientId       String            @map("patient_id") @db.Uuid
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  startAt         DateTime          @map("start_at")
  endAt           DateTime          @map("end_at")
  durationMinutes Int               @map("duration_minutes")
  type            AppointmentType   @map("type")
  status          AppointmentStatus @map("status")
  canceledAt      DateTime?         @map("canceled_at")
  canceledReason  String?           @map("canceled_reason")
  note            String?
  createdAt       DateTime          @map("created_at")
  updatedAt       DateTime          @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")
  records         Record[]

  @@map("appointment")
}

model WorkingHours {
  id             String       @id(map: "working_hours_pk") @db.Uuid
  professionalId String       @map("professional_id") @db.Uuid
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  dayOfWeek      Int          @map("day_of_week")
  startTime      String       @map("start_time")
  endTime        String       @map("end_time")
  slotDuration   Int          @map("slot_duration")
  active         Boolean      @default(true)
  createdAt      DateTime     @map("created_at")
  updatedAt      DateTime     @map("updated_at")

  @@map("working_hours")
}

model ProfessionalBlock {
  id             String       @id(map: "professional_block_pk") @db.Uuid
  professionalId String       @map("professional_id") @db.Uuid
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  startAt        DateTime     @map("start_at")
  endAt          DateTime     @map("end_at")
  reason         String?
  createdAt      DateTime     @map("created_at")
  updatedAt      DateTime     @map("updated_at")

  @@map("professional_block")
}

model Record {
  id             String                 @id(map: "record_pk") @db.Uuid
  professionalId String                 @map("professional_id") @db.Uuid
  professional   Professional           @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  patientId      String                 @map("patient_id") @db.Uuid
  patient        Patient                @relation(fields: [patientId], references: [id])
  description    String?
  templateType   EvolutionTemplateType? @map("template_type")
  title          String?
  attendanceType AttendanceType?        @map("attendance_type")
  clinicalStatus ClinicalStatusTag?     @map("clinical_status")
  conductTags    ConductTag[]           @map("conduct_tags")
  subjective     String?
  objective      String?
  assessment     String?
  plan           String?
  freeNotes      String?                @map("free_notes")
  eventDate      DateTime?              @map("event_date")
  appointmentId  String?                @map("appointment_id") @db.Uuid
  appointment    Appointment?           @relation(fields: [appointmentId], references: [id])
  files          File[]

  source             RecordSource      @default(MANUAL) @map("source")
  importedDocumentId String?           @map("imported_document_id") @db.Uuid
  importedDocument   ImportedDocument? @relation(fields: [importedDocumentId], references: [id])
  wasHumanEdited     Boolean           @default(false) @map("was_human_edited")

  patientFormId String?     @unique @map("patient_form_id") @db.Uuid
  patientForm   PatientForm? @relation("RecordPatientForm", fields: [patientFormId], references: [id])

  createdAt DateTime  @map("created_at")
  updatedAt DateTime  @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("record")
}

model File {
  id                String             @id(map: "file_pk") @db.Uuid
  recordId          String?            @map("record_id") @db.Uuid
  record            Record?            @relation(fields: [recordId], references: [id])
  patientId         String?            @map("patient_id") @db.Uuid
  patient           Patient?           @relation(fields: [patientId], references: [id])
  fileName          String
  url               String
  description       String
  createdAt         DateTime           @map("created_at")
  updatedAt         DateTime           @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")
  importedDocuments ImportedDocument[]

  @@map("file")
}

model ImportedDocument {
  id             String       @id(map: "imported_document_pk") @db.Uuid
  patientId      String       @map("patient_id") @db.Uuid
  patient        Patient      @relation(fields: [patientId], references: [id])
  professionalId String       @map("professional_id") @db.Uuid
  professional   Professional @relation(fields: [professionalId], references: [id])
  fileId         String       @map("file_id") @db.Uuid
  file           File         @relation(fields: [fileId], references: [id])

  documentType      String? @map("document_type")
  qualityLabel      String? @map("quality_label")
  qualityScore      Float?  @map("quality_score")
  rawOcrText        String? @map("raw_ocr_text")
  normalizedOcrText String? @map("normalized_ocr_text")
  ocrConfidence     Float?  @map("ocr_confidence")
  aiConfidence      Float?  @map("ai_confidence")

  status         ImportStatus @default(UPLOADED) @map("status")
  reviewRequired Boolean      @default(true) @map("review_required")

  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")

  extractedFields ExtractedField[]
  records         Record[]

  @@map("imported_document")
}

model ExtractedField {
  id                 String           @id(map: "extracted_field_pk") @db.Uuid
  importedDocumentId String           @map("imported_document_id") @db.Uuid
  importedDocument   ImportedDocument @relation(fields: [importedDocumentId], references: [id], onDelete: Cascade)

  fieldKey        String  @map("field_key")
  rawValue        String? @map("raw_value")
  structuredValue Json?   @map("structured_value")
  confidence      Float?  @map("confidence")
  needsReview     Boolean @default(true) @map("needs_review")
  correctedValue  Json?   @map("corrected_value")

  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")

  @@map("extracted_field")
}

model ClinicalProfile {
  id                 String       @id(map: "clinical_profile_pk") @db.Uuid
  patientId          String       @unique @map("patient_id") @db.Uuid
  patient            Patient      @relation(fields: [patientId], references: [id])
  professionalId     String       @map("professional_id") @db.Uuid
  professional       Professional @relation(fields: [professionalId], references: [id])
  allergies          String?
  chronicConditions  String?      @map("chronic_conditions")
  currentMedications String?      @map("current_medications")
  surgicalHistory    String?      @map("surgical_history")
  familyHistory      String?      @map("family_history")
  socialHistory      String?      @map("social_history")
  generalNotes       String?      @map("general_notes")
  createdAt          DateTime     @map("created_at")
  updatedAt          DateTime     @map("updated_at")

  @@map("clinical_profile")
}

model PatientAlert {
  id             String        @id(map: "patient_alert_pk") @db.Uuid
  patientId      String        @map("patient_id") @db.Uuid
  patient        Patient       @relation(fields: [patientId], references: [id])
  professionalId String        @map("professional_id") @db.Uuid
  professional   Professional  @relation(fields: [professionalId], references: [id])
  title          String
  description    String?
  severity       AlertSeverity
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @map("created_at")
  updatedAt      DateTime      @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  @@map("patient_alert")
}

enum FilePromotionStatus {
  PENDING
  IN_PROGRESS
  FAILED
  READY

  @@map("file_promotion_status")
}

model UploadFile {
  id                String              @id @db.Uuid
  tempPath          String              @map("temp_path")
  finalPath         String?             @map("final_path")
  status            FilePromotionStatus @default(PENDING) @map("status")
  promotionAttempts Int                 @default(0) @map("promotion_attempts")
  mimeType          String              @map("mime_type")
  size              Int
  checksum          String?
  createdAt         DateTime            @map("created_at")
  updatedAt         DateTime            @map("updated_at")

  @@map("upload_file")
}

model Event {
  id             Int      @id @default(autoincrement())
  type           String
  payload        Json     @db.JsonB
  userIp         String   @map("user_ip") @db.Inet
  userId         String?  @map("user_id") @db.Uuid
  professionalId String?  @map("professional_id") @db.Uuid
  timestamp      DateTime

  @@map("event")
}

model FormTemplate {
  id             String        @id(map: "form_template_pk") @db.Uuid
  code           String        @unique(map: "form_template_code_key")
  name           String
  description    String?
  specialty      Specialty
  isPublic       Boolean       @default(false) @map("is_public")
  professionalId String?       @map("professional_id") @db.Uuid
  professional   Professional? @relation(fields: [professionalId], references: [id])
  createdAt      DateTime      @map("created_at")
  updatedAt      DateTime      @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  versions     FormTemplateVersion[]
  patientForms PatientForm[]

  @@map("form_template")
}

model FormTemplateVersion {
  id             String       @id(map: "form_template_version_pk") @db.Uuid
  templateId     String       @map("template_id") @db.Uuid
  template       FormTemplate @relation(fields: [templateId], references: [id])
  versionNumber  Int          @map("version_number")
  status         FormStatus   @default(DRAFT) @map("status")
  definitionJson Json         @map("definition_json") @db.JsonB
  schemaJson     Json?        @map("schema_json") @db.JsonB
  publishedAt    DateTime?    @map("published_at")
  createdAt      DateTime     @map("created_at")
  updatedAt      DateTime     @map("updated_at")

  patientForms PatientForm[]

  @@unique([templateId, versionNumber], name: "form_template_version_unique")
  @@map("form_template_version")
}

model PatientForm {
  id             String              @id(map: "patient_form_pk") @db.Uuid
  patientId      String              @map("patient_id") @db.Uuid
  patient        Patient             @relation(fields: [patientId], references: [id])
  professionalId String              @map("professional_id") @db.Uuid
  professional   Professional        @relation(fields: [professionalId], references: [id])
  templateId     String              @map("template_id") @db.Uuid
  template       FormTemplate        @relation(fields: [templateId], references: [id])
  versionId      String              @map("version_id") @db.Uuid
  version        FormTemplateVersion @relation(fields: [versionId], references: [id])
  status         FormResponseStatus  @default(IN_PROGRESS) @map("status")
  responseJson   Json                @map("response_json") @db.JsonB
  computedJson   Json?               @map("computed_json") @db.JsonB
  appliedAt      DateTime            @map("applied_at")
  completedAt    DateTime?           @map("completed_at")
  createdAt      DateTime            @map("created_at")
  updatedAt      DateTime            @map("updated_at")

  record     Record?          @relation("RecordPatientForm")
  fieldIndex FormFieldIndex[]

  @@map("patient_form")
}

model FormFieldIndex {
  id            String      @id(map: "form_field_index_pk") @db.Uuid
  patientFormId String      @map("patient_form_id") @db.Uuid
  patientForm   PatientForm @relation(fields: [patientFormId], references: [id])
  fieldId       String      @map("field_id")
  fieldLabel    String?     @map("field_label")
  fieldType     String?     @map("field_type")
  valueText     String?     @map("value_text")
  valueNumber   Float?      @map("value_number")
  valueBoolean  Boolean?    @map("value_boolean")
  valueDate     DateTime?   @map("value_date")
  valueJson     Json?       @map("value_json") @db.JsonB
  specialty     Specialty
  confidence    Float?
  createdAt     DateTime    @map("created_at")
  updatedAt     DateTime    @map("updated_at")

  @@unique([patientFormId, fieldId], name: "form_field_index_unique")
  @@index([specialty], name: "form_field_index_specialty_idx")
  @@index([fieldId], name: "form_field_index_field_id_idx")
  @@index([valueText], name: "form_field_index_value_text_idx")
  @@index([valueNumber], name: "form_field_index_value_number_idx")
  @@map("form_field_index")
}

// ─── Clinical Chat & RAG ──────────────────────────────────────────────────────

enum ChatSessionStatus {
  ACTIVE
  CLOSED
  ARCHIVED

  @@map("chat_session_status")
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
  /// Mensagem interna de pipeline (ex: contexto injetado, trace). Não exibida ao usuário.
  INTERNAL

  @@map("chat_message_role")
}

enum ContextChunkSourceType {
  RECORD
  PATIENT_FORM
  CLINICAL_PROFILE
  PATIENT_ALERT
  IMPORTED_DOCUMENT

  @@map("context_chunk_source_type")
}

enum ContextSnapshotStatus {
  PENDING
  READY
  /// Snapshot desatualizado — novos records/formulários foram criados depois
  STALE
  FAILED

  @@map("context_snapshot_status")
}

/// Perfil de agente clínico por profissão/especialidade.
/// Catálogo versionado e configurável — carregado pelo ChatService sem hardcode.
model AiAgentProfile {
  id               String     @id(map: "ai_agent_profile_pk") @db.Uuid
  name             String
  /// Identificador programático em snake_case, ex: "medico_geral", "psicologia_clinica"
  code             String?    @unique(map: "ai_agent_profile_code_key")
  /// Identificador único legível por humanos, ex: "psicologia-adulto"
  slug             String     @unique(map: "ai_agent_profile_slug_key")
  /// Grupo de especialidade, ex: "medicina", "psicologia"
  specialtyGroup   String?    @map("specialty_group")
  /// null = agente genérico; preenchido = agente especialista
  specialty        Specialty?
  description      String?
  /// Instruções base para o prompt do agente (system prompt).
  baseInstructions String?    @map("base_instructions") @db.Text
  /// Tipos de fonte que este agente pode usar (ex: ["RECORD","CLINICAL_PROFILE"])
  allowedSources   String[]   @map("allowed_sources")
  /// Configuração de prioridade de contexto por tipo de dado (JsonB livre)
  contextPriority  Json?      @map("context_priority") @db.JsonB
  /// Campos específicos de JSONB clínico que têm maior peso na análise
  priorityFields   Json?      @map("priority_fields") @db.JsonB
  /// Objetivos de análise do agente (ex: ["summary", "hypotheses", "next_steps"])
  analysisGoals    String[]   @map("analysis_goals")
  /// Restrições comportamentais do agente (guardrails de segurança clínica)
  guardrails       String?    @db.Text
  /// Estilo de resposta preferido (ex: formato, tom, estrutura)
  responseStyle    String?    @map("response_style") @db.Text
  /// Modelo fixo a ser usado por este agente no OpenRouter (ex: "openai/o1-mini").
  /// Quando null, o sistema usa o modelo padrão da especialidade (specialty-model-defaults).
  /// O valor "openrouter/auto" é bloqueado — o comportamento de roteamento automático não é permitido.
  providerModelId  String?    @map("provider_model_id")
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @map("created_at")
  updatedAt        DateTime   @map("updated_at")

  sessions PatientChatSession[]

  @@map("ai_agent_profile")
}

/// Sessão de chat clínico entre um profissional e o contexto de um paciente.
model PatientChatSession {
  id             String            @id(map: "patient_chat_session_pk") @db.Uuid
  patientId      String            @map("patient_id") @db.Uuid
  patient        Patient           @relation(fields: [patientId], references: [id])
  professionalId String            @map("professional_id") @db.Uuid
  professional   Professional      @relation(fields: [professionalId], references: [id])
  agentProfileId String?           @map("agent_profile_id") @db.Uuid
  agentProfile   AiAgentProfile?   @relation(fields: [agentProfileId], references: [id])
  title          String?
  status         ChatSessionStatus @default(ACTIVE) @map("status")
  lastActivityAt DateTime          @map("last_activity_at")
  createdAt      DateTime          @map("created_at")
  updatedAt      DateTime          @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")

  messages         PatientChatMessage[]
  interactionLogs  ClinicalChatInteractionLog[]

  @@index([patientId], name: "patient_chat_session_patient_idx")
  @@index([professionalId], name: "patient_chat_session_professional_idx")
  @@map("patient_chat_session")
}

/// Mensagem individual de uma sessão de chat clínico.
/// Nesta etapa não há resposta real de IA — a estrutura está pronta para plugar um LLM.
model PatientChatMessage {
  id        String             @id(map: "patient_chat_message_pk") @db.Uuid
  sessionId String             @map("session_id") @db.Uuid
  session   PatientChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      ChatMessageRole    @map("role")
  content   String             @db.Text
  /// Metadados opcionais (ex: modelo utilizado, latência, flags)
  metadata  Json?              @db.JsonB
  /// IDs dos PatientContextChunks usados como contexto nesta mensagem (rastreabilidade RAG)
  chunkIds  String[]           @map("chunk_ids")
  createdAt DateTime           @map("created_at")
  updatedAt DateTime           @map("updated_at")

  @@index([sessionId], name: "patient_chat_message_session_idx")
  @@map("patient_chat_message")
}

/// Snapshot consolidado do contexto clínico de um paciente.
/// Usado para economizar tokens em sessões de chat futuras — serve como cache semântico.
model PatientContextSnapshot {
  id             String                @id(map: "patient_context_snapshot_pk") @db.Uuid
  patientId      String                @map("patient_id") @db.Uuid
  patient        Patient               @relation(fields: [patientId], references: [id])
  /// null = snapshot genérico; preenchido = snapshot com perspectiva de um profissional
  professionalId String?               @map("professional_id") @db.Uuid
  professional   Professional?         @relation(fields: [professionalId], references: [id])
  /// Facts estruturados do paciente (dados demográficos, condições, medicamentos, etc.)
  patientFacts   Json                  @map("patient_facts") @db.JsonB
  /// Alertas e informações críticas (alergias, contraindicações)
  criticalContext Json?                @map("critical_context") @db.JsonB
  /// Timeline resumida dos últimos records e formulários
  timelineSummary Json?               @map("timeline_summary") @db.JsonB
  /// Hash dos dados usados para detectar quando o snapshot ficou stale
  contentHash    String                @map("content_hash")
  status         ContextSnapshotStatus @default(PENDING) @map("status")
  builtAt        DateTime?             @map("built_at")
  createdAt      DateTime              @map("created_at")
  updatedAt      DateTime              @map("updated_at")

  @@unique([patientId, professionalId], name: "patient_context_snapshot_unique")
  @@index([patientId], name: "patient_context_snapshot_patient_idx")
  @@map("patient_context_snapshot")
}

/// Chunk indexável para RAG — representa um pedaço de conteúdo clínico do paciente.
///
/// EMBEDDING: O campo `embedding` é um placeholder para vetorização.
/// Quando pgvector for ativado:
///   1. Adicionar ao datasource: extensions = [pgvector(map: "vector")]
///   2. Substituir `Json?` por `Unsupported("vector(1536)")`
///   3. Adicionar índice: @@index([embedding], type: Hnsw, ops: VectorCosineOps)
model PatientContextChunk {
  id         String                 @id(map: "patient_context_chunk_pk") @db.Uuid
  patientId  String                 @map("patient_id") @db.Uuid
  patient    Patient                @relation(fields: [patientId], references: [id])
  sourceType ContextChunkSourceType @map("source_type")
  /// ID da entidade de origem (Record.id, PatientForm.id, etc.)
  sourceId   String                 @map("source_id") @db.Uuid
  content    String                 @db.Text
  /// Metadados do chunk (título do record, data, specialty, etc.)
  metadata   Json?                  @db.JsonB
  chunkIndex Int                    @default(0) @map("chunk_index")
  /// Embedding vetorial do chunk para busca semântica via pgvector.
  /// Gerado pelo EmbeddingProvider (nunca pelo ChatProvider).
  embedding  Unsupported("vector(1536)")?  @map("embedding")
  /// Hash do conteúdo — permite detectar se a fonte mudou e re-indexar
  contentHash String               @map("content_hash")
  createdAt  DateTime               @map("created_at")
  updatedAt  DateTime               @map("updated_at")

  @@unique([patientId, sourceType, sourceId, chunkIndex], name: "patient_context_chunk_unique")
  @@index([patientId], name: "patient_context_chunk_patient_idx")
  @@index([sourceType, sourceId], name: "patient_context_chunk_source_idx")
  // Nota: índice HNSW (embedding vector_cosine_ops) é criado via migration SQL —
  // Prisma v6 não suporta a sintaxe @@index para tipos pgvector.
  @@map("patient_context_chunk")
}

/// Status de uma interação de chat com IA.
enum ChatInteractionStatus {
  PENDING
  COMPLETED
  FAILED
  /// Resposta gerada por fallback (ex: provider indisponível, usado mock)
  FALLBACK

  @@map("chat_interaction_status")
}

/// Log de auditoria de uma interação de chat clínico com IA.
/// Separa os dados de execução/rastreabilidade das mensagens em si.
/// Permite auditoria completa de: provider usado, tokens, latência, chunks recuperados.
model ClinicalChatInteractionLog {
  id                 String               @id(map: "clinical_chat_interaction_log_pk") @db.Uuid
  sessionId          String               @map("session_id") @db.Uuid
  session            PatientChatSession   @relation(fields: [sessionId], references: [id])
  /// ID da mensagem do usuário que originou esta interação
  userMessageId      String               @map("user_message_id") @db.Uuid
  /// ID da mensagem do assistente gerada (null se a geração falhou)
  assistantMessageId String?              @map("assistant_message_id") @db.Uuid

  // ─── Provider & Model ───────────────────────────────────────────────────────
  /// Identificador do provider usado (ex: "openai", "anthropic", "mock")
  providerId         String?              @map("provider_id")
  /// Identificador do modelo usado (ex: "gpt-4o", "claude-3-5-sonnet", "mock-clinical-assistant-v1")
  modelId            String?              @map("model_id")
  agentProfileId     String?              @map("agent_profile_id") @db.Uuid
  /// Slug do agente usado, para leitura humana sem JOIN
  agentSlug          String?              @map("agent_slug")

  // ─── Rastreabilidade de contexto ────────────────────────────────────────────
  /// ID do snapshot usado como contexto base
  snapshotId         String?              @map("snapshot_id") @db.Uuid
  /// Hash do snapshot no momento da interação (detecta se estava stale)
  snapshotVersion    String?              @map("snapshot_version")
  /// IDs dos PatientContextChunks recuperados via RAG para esta interação
  retrievedChunkIds  String[]             @map("retrieved_chunk_ids")

  // ─── Uso de tokens ──────────────────────────────────────────────────────────
  promptTokens       Int?                 @map("prompt_tokens")
  completionTokens   Int?                 @map("completion_tokens")
  totalTokens        Int?                 @map("total_tokens")

  // ─── Performance ────────────────────────────────────────────────────────────
  latencyMs          Int?                 @map("latency_ms")

  // ─── Status & erros ─────────────────────────────────────────────────────────
  status             ChatInteractionStatus @default(PENDING) @map("status")
  errorCode          String?              @map("error_code")
  errorMessage       String?              @map("error_message") @db.Text

  // ─── Flags ──────────────────────────────────────────────────────────────────
  /// true se a resposta foi gerada por um provider de fallback
  usedFallback       Boolean              @default(false) @map("used_fallback")

  createdAt          DateTime             @map("created_at")
  updatedAt          DateTime             @map("updated_at")

  @@index([sessionId], name: "clinical_chat_interaction_log_session_idx")
  @@map("clinical_chat_interaction_log")
}
