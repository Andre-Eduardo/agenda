  FAILED
  FALLBACK

  @@map("chat_interaction_status")
}

/// MUDANÇA: clinicId adicionado para isolamento de tenant.
model ClinicalChatInteractionLog {
  id                 String                @id(map: "clinical_chat_interaction_log_pk") @db.Uuid
  clinicId           String                @map("clinic_id") @db.Uuid
  clinic             Clinic                @relation(fields: [clinicId], references: [id])
  sessionId          String                @map("session_id") @db.Uuid
  session            PatientChatSession    @relation(fields: [sessionId], references: [id])
  userMessageId      String                @map("user_message_id") @db.Uuid
  assistantMessageId String?               @map("assistant_message_id") @db.Uuid

  providerId     String? @map("provider_id")
  modelId        String? @map("model_id")
  agentProfileId String? @map("agent_profile_id") @db.Uuid
  agentSlug      String? @map("agent_slug")

  snapshotId        String?  @map("snapshot_id") @db.Uuid
  snapshotVersion   String?  @map("snapshot_version")
  retrievedChunkIds String[] @map("retrieved_chunk_ids")

  promptTokens     Int? @map("prompt_tokens")
  completionTokens Int? @map("completion_tokens")
  totalTokens      Int? @map("total_tokens")

  latencyMs Int? @map("latency_ms")

  status       ChatInteractionStatus @default(PENDING) @map("status")
  errorCode    String?               @map("error_code")
  errorMessage String?               @map("error_message") @db.Text

  usedFallback Boolean @default(false) @map("used_fallback")

  // ─── Agent observability ────────────────────────────────────────────────────
  /// Names of agent tools called during this interaction
  toolNames       String[] @default([]) @map("tool_names")
  /// IDs of AgentProposals created during this interaction
  proposalIds     String[] @default([]) @map("proposal_ids")
  /// Number of agent loop iterations performed
  totalIterations Int?     @map("total_iterations")
  /// Number of RAG chunks used as context
  ragChunksUsed   Int?     @map("rag_chunks_used")
