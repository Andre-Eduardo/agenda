generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

model Event {
  id        Int      @id @default(autoincrement())
  type      String
  payload   Json     @db.JsonB
  userIp    String   @map("user_ip") @db.Inet
  userId    String?  @map("user_id") @db.Uuid
  companyId String?  @map("company_id") @db.Uuid
  timestamp DateTime

  @@map("event")
}

model User {
  id         String     @id(map: "user_pk") @db.Uuid
  username   String     @unique @db.Citext()
  email      String?    @unique @db.Citext()
  name       String     @map("name")
  password   String
  phone      String?
  globalRole GlobalRole @map("global_role")
  createdAt  DateTime   @map("created_at")
  updatedAt  DateTime   @map("updated_at")

  professionals Professional[]

  @@map("user")
}

enum GlobalRole {
  SUPER_ADMIN
  OWNER
  NONE

  @@map("global_role")
}

enum Gender {
  MALE
  FEMALE
  OTHER

  @@map("gender")
}

enum PersonProfile {
  PROFESSIONAL
  PATIENT

  @@map("person_profile")
}

enum PersonType {
  NATURAL
  LEGAL

  @@map("person_type")
}

model Person {
  id            String         @id(map: "person_pk") @db.Uuid
  name          String
  documentId    String         @map("document_id")
  phone         String?
  gender        Gender?
  personType    PersonType     @map("person_type")
  createdAt     DateTime       @map("created_at")
  updatedAt     DateTime       @map("updated_at")
  professionals Professional[]
  patients      Patient[]

  @@unique([documentId], name: "person_document_id_key")
  @@map("person")
}

model Professional {
  id                String        @id(map: "professional_pk") @db.Uuid
  person            Person        @relation(fields: [id], references: [id], onDelete: Cascade)
  allowSystemAccess Boolean       @map("allow_system_access")
  userId            String?       @map("user_id") @db.Uuid
  user              User?         @relation(fields: [userId], references: [id])
  specialty         String?
  createdAt         DateTime      @map("created_at")
  updatedAt         DateTime      @map("updated_at")
  appointments      Appointment[]
  records           Record[]

  @@map("professional")
}

model Patient {
  id           String        @id(map: "patient_pk") @db.Uuid
  person       Person        @relation(fields: [id], references: [id], onDelete: Cascade)
  records      Record[]
  createdAt    DateTime      @map("created_at")
  updatedAt    DateTime      @map("updated_at")
  appointments Appointment[]

  @@map("patient")
}

model Appointment {
  id             String       @id(map: "appointment_pk") @db.Uuid
  patientId      String       @map("patient_id") @db.Uuid
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professionalId String       @map("professional_id") @db.Uuid
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  date           DateTime     @map("date")
  canceledAt     DateTime?    @map("canceled_at")
  canceledReason String?      @map("canceled_reason")
  note           String?
  createdAt      DateTime     @map("created_at")
  updatedAt      DateTime     @map("updated_at")

  @@map("appointment")
}

model Record {
  id             String       @id(map: "record_pk") @db.Uuid
  patient        Patient      @relation(fields: [patientId], references: [id])
  patientId      String       @map("patient_id") @db.Uuid
  professional   Professional @relation(fields: [professionalId], references: [id])
  professionalId String       @map("professional_id") @db.Uuid
  description    String
  files          File[]
  createdAt      DateTime     @map("created_at")
  updatedAt      DateTime     @map("updated_at")

  @@map("record")
}

model File {
  id          String   @id(map: "file_pk") @db.Uuid
  record      Record   @relation(fields: [recordId], references: [id])
  recordId    String   @map("record_id") @db.Uuid
  fileName    String
  url         String
  description String
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  @@map("file")
}
