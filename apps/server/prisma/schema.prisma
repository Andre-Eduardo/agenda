generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

model User {
  id         String     @id(map: "user_pk") @db.Uuid
  username   String     @unique @db.Citext()
  email      String?    @unique @db.Citext()
  name       String     @map("name")
  password   String
  phone      String?
  globalRole GlobalRole @map("global_role")
  createdAt  DateTime   @map("created_at")
  updatedAt  DateTime   @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")

  professionals Professional[]

  @@map("user")
}

enum GlobalRole {
  SUPER_ADMIN
  OWNER
  NONE

  @@map("global_role")
}

enum Gender {
  MALE
  FEMALE
  OTHER

  @@map("gender")
}

enum PersonProfile {
  PROFESSIONAL
  PATIENT

  @@map("person_profile")
}

enum PersonType {
  NATURAL
  LEGAL

  @@map("person_type")
}

model Person {
  id           String        @id(map: "person_pk") @db.Uuid
  name         String
  documentId   String        @map("document_id")
  phone        String?
  gender       Gender?
  personType   PersonType    @map("person_type")
  createdAt    DateTime      @map("created_at")
  updatedAt    DateTime      @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")
  professional Professional?
  patients     Patient[]

  @@unique([documentId], name: "person_document_id_key")
  @@map("person")
}

// 🔑 Professional com config 1:1 (igual Company)
model Professional {
  id        String             @id(map: "professional_pk") @db.Uuid
  personId  String             @unique @map("person_id") @db.Uuid
  person    Person             @relation(fields: [personId], references: [id])
  configId  String             @unique(map: "professional_config_id_key") @map("config_id") @db.Uuid
  config    ProfessionalConfig @relation(references: [id], fields: [configId])
  userId    String             @map("user_id") @db.Uuid
  user      User               @relation(fields: [userId], references: [id])
  specialty String?
  createdAt DateTime           @map("created_at")
  updatedAt DateTime           @map("updated_at")
  deletedAt DateTime?          @map("deleted_at")

  appointments       Appointment[]
  records            Record[]
  patients           Patient[]
  workingHours       WorkingHours[]
  professionalBlocks ProfessionalBlock[]

  @@map("professional")
}

model ProfessionalConfig {
  id        String   @id(map: "professional_config_pk") @db.Uuid
  color     String?
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  professional Professional?

  @@map("professional_config")
}

model Patient {
  id             String        @id(map: "patient_pk") @db.Uuid
  person         Person        @relation(fields: [id], references: [id], onDelete: Cascade)
  documentId     String        @map("document_id") @db.Citext()
  createdAt      DateTime      @map("created_at")
  updatedAt      DateTime      @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")
  appointments   Appointment[]
  records        Record[]
  professional   Professional? @relation(fields: [professionalId], references: [id])
  professionalId String?       @db.Uuid

  @@unique([documentId], name: "patient_document_id_key")
  @@map("patient")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW

  @@map("appointment_status")
}

enum AppointmentType {
  FIRST_VISIT
  RETURN
  WALK_IN
  TELEMEDICINE
  PROCEDURE

  @@map("appointment_type")
}

model Appointment {
  id              String            @id(map: "appointment_pk") @db.Uuid
  professionalId  String            @map("professional_id") @db.Uuid
  professional    Professional      @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  patientId       String            @map("patient_id") @db.Uuid
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  startAt         DateTime          @map("start_at")
  endAt           DateTime          @map("end_at")
  durationMinutes Int               @map("duration_minutes")
  type            AppointmentType   @map("type")
  status          AppointmentStatus @map("status")
  canceledAt      DateTime?         @map("canceled_at")
  canceledReason  String?           @map("canceled_reason")
  note            String?
  createdAt       DateTime          @map("created_at")
  updatedAt       DateTime          @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  @@map("appointment")
}

model WorkingHours {
  id             String       @id(map: "working_hours_pk") @db.Uuid
  professionalId String       @map("professional_id") @db.Uuid
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  dayOfWeek      Int          @map("day_of_week")
  startTime      String       @map("start_time")
  endTime        String       @map("end_time")
  slotDuration   Int          @map("slot_duration")
  active         Boolean      @default(true)
  createdAt      DateTime     @map("created_at")
  updatedAt      DateTime     @map("updated_at")

  @@map("working_hours")
}

model ProfessionalBlock {
  id             String       @id(map: "professional_block_pk") @db.Uuid
  professionalId String       @map("professional_id") @db.Uuid
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  startAt        DateTime     @map("start_at")
  endAt          DateTime     @map("end_at")
  reason         String?
  createdAt      DateTime     @map("created_at")
  updatedAt      DateTime     @map("updated_at")

  @@map("professional_block")
}

model Record {
  id             String       @id(map: "record_pk") @db.Uuid
  professionalId String       @map("professional_id") @db.Uuid
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  patientId      String       @map("patient_id") @db.Uuid
  patient        Patient      @relation(fields: [patientId], references: [id])
  description    String
  files          File[]
  createdAt      DateTime     @map("created_at")
  updatedAt      DateTime     @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  @@map("record")
}

model File {
  id          String   @id(map: "file_pk") @db.Uuid
  recordId    String   @map("record_id") @db.Uuid
  record      Record   @relation(fields: [recordId], references: [id])
  fileName    String
  url         String
  description String
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("file")
}

enum FilePromotionStatus {
  PENDING
  IN_PROGRESS
  FAILED
  READY

  @@map("file_promotion_status")
}

model UploadFile {
  id                String              @id @db.Uuid
  tempPath          String              @map("temp_path")
  finalPath         String?             @map("final_path")
  status            FilePromotionStatus @default(PENDING) @map("status")
  promotionAttempts Int                 @default(0) @map("promotion_attempts")
  mimeType          String              @map("mime_type")
  size              Int
  checksum          String?
  createdAt         DateTime            @map("created_at")
  updatedAt         DateTime            @map("updated_at")

  @@map("upload_file")
}

model Event {
  id             Int      @id @default(autoincrement())
  type           String
  payload        Json     @db.JsonB
  userIp         String   @map("user_ip") @db.Inet
  userId         String?  @map("user_id") @db.Uuid
  professionalId String?  @map("professional_id") @db.Uuid
  timestamp      DateTime

  @@map("event")
}
