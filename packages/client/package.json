{
  "name": "@agenda-app/client",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt",
    "code-check": "oxlint --type-check && oxfmt --check",
    "generate": "orval",
    "codegen": "orval && pnpm lint:fix && pnpm build",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.71.10",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@stoplight/spectral-rulesets": "^1.22.1",
    "orval": "^7.6.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.18.0",
    "typescript": "^5.8.3",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.3"
  }
}
